{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Coding Agent VA",
  "version": "0.1.0",
  "identifier": "com.codingagent.va.desktop",
  "build": {
    "beforeDevCommand": "bash -lc 'repo_root=\"$(git rev-parse --show-toplevel)\" && just --justfile \"$repo_root/justfile\" --working-directory \"$repo_root\" dev-ts'",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bash -lc 'repo_root=\"$(git rev-parse --show-toplevel)\" && just --justfile \"$repo_root/justfile\" --working-directory \"$repo_root\" build-ts'",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Coding Agent VA",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
