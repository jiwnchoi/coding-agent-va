rust_manifest := "src-tauri/Cargo.toml"
set dotenv-load := true

export RUST_BACKTRACE := "1"

prepare-rust:
  cargo fetch --manifest-path {{rust_manifest}}

dev-rust:
  ./node_modules/.bin/tauri dev

format-rust:
  cargo fmt --all --manifest-path {{rust_manifest}}

lint-rust:
  cargo clippy --manifest-path {{rust_manifest}} --all-targets -- -D warnings

typecheck-rust:
  cargo check --manifest-path {{rust_manifest}} --all-targets

compile-rust:
  cargo check --manifest-path {{rust_manifest}} --all-targets

build-rust:
  cargo build --manifest-path {{rust_manifest}}

test-rust:
  cargo test --manifest-path {{rust_manifest}}
