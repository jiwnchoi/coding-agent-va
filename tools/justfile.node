node_modules_bin := "./node_modules/.bin"
package_manager := `node -p 'require("./package.json").packageManager.split("+")[0]'`

prepare-node:
  corepack {{package_manager}} install --frozen-lockfile

node-install: prepare-node

dev-ts:
  ./node_modules/.bin/vite

lint-ts:
  ./node_modules/.bin/oxlint src vite.config.ts --type-aware

format-ts:
  ./node_modules/.bin/oxfmt --write src vite.config.ts

typecheck-ts:
  ./node_modules/.bin/tsgo -p tsconfig.json --noEmit

compile-ts:
  @just build-ts

build-ts:
  ./node_modules/.bin/tsgo -p tsconfig.json --noEmit
  ./node_modules/.bin/vite build

test-ts:
  echo 'No TS test commands configured; skipping.'
