node_modules_bin := "./node_modules/.bin"
app_dir := "app"
app_node_modules_bin := "./app/node_modules/.bin"
package_manager := `node -p 'require("./package.json").packageManager.split("+")[0]'`

prepare-node:
  corepack {{package_manager}} install --frozen-lockfile

node-install: prepare-node

dev-ts:
  (cd app && ./node_modules/.bin/vite)

lint-ts:
  (cd app && ../node_modules/.bin/oxlint src vite.config.ts --type-aware)
  (cd packages/codex-protocol && ../../node_modules/.bin/oxlint src --type-aware)
  (cd packages/graph-indexer && ../../node_modules/.bin/oxlint src --type-aware)
  (cd packages/mcp-visualization-server && ../../node_modules/.bin/oxlint src --type-aware)

format-ts:
  (cd app && ../node_modules/.bin/oxfmt --write src vite.config.ts)
  (cd packages/codex-protocol && ../../node_modules/.bin/oxfmt --write src)
  (cd packages/graph-indexer && ../../node_modules/.bin/oxfmt --write src)
  (cd packages/mcp-visualization-server && ../../node_modules/.bin/oxfmt --write src)

typecheck-ts:
  (cd app && ../node_modules/.bin/tsgo -p tsconfig.json --noEmit)
  (cd packages/codex-protocol && ../../node_modules/.bin/tsgo -p tsconfig.json --noEmit)
  (cd packages/graph-indexer && ../../node_modules/.bin/tsgo -p tsconfig.json --noEmit)
  (cd packages/mcp-visualization-server && ../../node_modules/.bin/tsgo -p tsconfig.json --noEmit)

compile-ts:
  @just build-ts

build-ts:
  (cd packages/codex-protocol && ../../node_modules/.bin/tsgo -p tsconfig.json)
  (cd packages/graph-indexer && ../../node_modules/.bin/tsgo -p tsconfig.json)
  (cd packages/mcp-visualization-server && ../../node_modules/.bin/tsgo -p tsconfig.json)
  (cd app && ../node_modules/.bin/tsgo -p tsconfig.json --noEmit)
  (cd app && ./node_modules/.bin/vite build)

test-ts:
  echo 'No TS test commands configured; skipping.'
